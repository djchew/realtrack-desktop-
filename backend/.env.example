# Path to the SQLite database file.
# Electron sets this automatically to the user's AppData folder in production.
DB_PATH=./realtrack.db

# Sentry DSN for backend error tracking (optional — leave blank to disable).
# Get yours at https://sentry.io after creating a Python project.
SENTRY_DSN_BACKEND=

# Comma-separated allowed CORS origins (default: http://localhost:3000)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
